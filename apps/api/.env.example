# ─────────────────────────────────────────────────────────────
# SpendWisely API — Environment Variables
# Copy this file to apps/api/.env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# Supabase (get from your Supabase project → Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Redis (local via docker compose)
REDIS_URL=redis://localhost:6379

# RabbitMQ (local via docker compose)
RABBITMQ_URL=amqp://sika:dev_password@localhost:5672

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-byte-hex-string
JWT_REFRESH_SECRET=replace-with-different-64-byte-hex-string

# Encryption key for OAuth tokens at rest — must be exactly 64 hex chars (32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace-with-64-hex-char-string-exactly

# Google OAuth (from Google Cloud Console → APIs & Services → Credentials)
# Required scopes: gmail.readonly, userinfo.email
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/gmail/callback

# Arkesel SMS Gateway (from https://arkesel.com → Dashboard → API Keys)
ARKESEL_API_KEY=your-arkesel-api-key
ARKESEL_SENDER_ID=SpendWisely

# SMTP Email Settings (for welcome and transaction email alerts)
SMTP_HOST=your-smtp-host (e.g. smtp.mailtrap.io or smtp.gmail.com)
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_SECURE=false
SMTP_FROM="SpendWisely <noreply@spendwisely.com>"

