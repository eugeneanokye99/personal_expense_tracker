    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "supertest": "^7.2.2",
    "tsx": "^4.15.2",
    "typescript": "^5.4.5",
    "vitest": "^4.1.7"
